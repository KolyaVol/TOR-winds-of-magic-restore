<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <AssemblyName>WindsOfMagicRestore</AssemblyName>
    <RootNamespace>WindsOfMagicRestore</RootNamespace>
    <OutputPath>..\..\build\WindsOfMagicRestore\bin\Win64_Shipping_Client\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Bannerlord.ReferenceAssemblies" Version="1.3.15.110062" />
    <PackageReference Include="Bannerlord.MCM" Version="5.11.3" IncludeAssets="compile" />
  </ItemGroup>

  <Target Name="CopyModuleOutputs" AfterTargets="Build">
    <Copy SourceFiles="$(ProjectDir)_Module\SubModule.xml" DestinationFolder="$(ProjectDir)..\..\build\WindsOfMagicRestore\" SkipUnchangedFiles="true" />
  </Target>
</Project>
